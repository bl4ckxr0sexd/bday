# ============================================================================
#  BIRTHDAY INVITE — CONFIG (example / reference)
#  Copy this file to ".env" and fill in your own values, then `npm run build`.
#    cp .env.example .env
# ============================================================================

# The birthday person's name (used on the email + landing page).
COUSIN_NAME=Your Cousin

# How the email greets the reader, e.g. "Hi there! 👋".
# A fixed word ("there"/"friend") for a broadcast email, or your mail tool's
# merge tag (e.g. *|FNAME|*) to personalise per recipient.
GUEST_NAME=there

# Your live landing page URL (goes in the email button).
LANDING_URL=https://your-project.vercel.app

# The Google Drive link for the downloadable invitation.
# Forced download form: https://drive.google.com/uc?export=download&id=YOUR_FILE_ID
DOWNLOAD_URL=https://drive.google.com/file/d/YOUR_GOOGLE_DRIVE_FILE_ID/view?usp=sharing

# Google Apps Script Web App URL (ends in /exec). Leave blank to disable tracking.
TRACKING_ENDPOINT=

# Party details (shown as cards on the landing page).
PARTY_DATE=July 15, 2026
PARTY_DATE_NOTE=Wednesday
PARTY_TIME=4:00 PM
PARTY_TIME_NOTE=Onwards
DRESS_CODE=Bright & Colorful
DRESS_CODE_NOTE=Come ready to have fun!
