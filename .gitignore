# Build output (regenerated by `npm run build` / Vercel)
public/

# Node
node_modules/
npm-debug.log*

# OS
.DS_Store

# NOTE: .env IS intentionally committed here — it holds no real secrets for
# this template (just names, party details, and public URLs), and committing
# it lets Vercel build with your values. If you ever put something sensitive
# in .env, add it to this file and use the Vercel dashboard env vars instead.
