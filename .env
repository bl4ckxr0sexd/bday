# ============================================================================
#  BIRTHDAY INVITE — CONFIG
#  Edit the values on the right of each "=" then run `npm run build`
#  (Vercel runs the build automatically on every deploy.)
#  Tip: keep values on ONE line. Quotes are optional.
# ============================================================================

# NOTE: This .env configures the LANDING PAGE only.
# The email letter is a separate standalone file — edit values directly at the
# top of email.html (email clients can't run a build).

# --- The basics -------------------------------------------------------------
# The birthday person's name (shown on the landing page).
COUSIN_NAME=Rohan

# --- Links ------------------------------------------------------------------
# The Google Drive link for the downloadable invitation.
# For a forced download use: https://drive.google.com/uc?export=download&id=YOUR_FILE_ID
DOWNLOAD_URL=https://drive.google.com/file/d/YOUR_GOOGLE_DRIVE_FILE_ID/view?usp=sharing

# Your Google Apps Script Web App URL (ends in /exec). Leave blank to disable tracking.
TRACKING_ENDPOINT=

# --- Share preview ----------------------------------------------------------
# Only used for the link-preview text when the page is shared in chats.
# (The landing page itself just shows the invite + download button; the full
#  details live in the downloadable file.)
PARTY_DATE=July 15, 2026
PARTY_TIME=4:00 PM
